{
  "name": "ssid-docs",
  "version": "1.0.0",
  "type": "module",
  "description": "Public documentation site for SSID",
  "scripts": {
    "dev": "astro dev --port 4331",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "node tests/run.mjs",
    "test:build": "astro build",
    "test:structure": "node tests/structure.test.mjs",
    "test:content": "node tests/content.test.mjs",
    "test:theme": "node tests/theme.test.mjs",
    "ingest": "node tools/ingest.mjs"
  },
  "keywords": ["ssid", "ssi", "documentation", "astro", "starlight"],
