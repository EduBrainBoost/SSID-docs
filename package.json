  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp"]
  },
  "dependencies": {
    "@astrojs/starlight": "^0.37.6",
    "astro": "^5.18.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3"
